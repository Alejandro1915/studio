rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Collection
    match /users/{userId} {
      // Anyone can read a user's profile
      allow read: if request.auth != null;
      // A user can only create their own document
      allow create: if request.auth.uid == userId;
      // A user can only update their own document
      allow update: if request.auth.uid == userId;
      // Users cannot delete their accounts from the client
      allow delete: if false;
    }
    
    // Questions Collection
    match /questions/{questionId} {
      // Any authenticated user can read questions
      allow read: if request.auth != null;
      // Only admins can create, update, or delete questions
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Games Collection
    match /games/{gameId} {
      allow read: if request.auth != null;
      allow create: if request.resource.data.hostId == request.auth.uid;
      // Allow update if the user is the host OR if they are joining a game that has less than 2 players
      allow update: if request.auth.uid == resource.data.hostId || (request.resource.data.players.size() == 2 && resource.data.players.size() == 1 && request.auth.uid in request.resource.data.players);
      allow delete: if request.auth.uid == resource.data.hostId;
    }

    // Invitations Collection
    match /invitations/{inviteId} {
      // A user can read an invitation if they are the recipient
      allow read: if request.auth.uid == resource.data.toUid;
      // A user can create an invitation if they are the sender
      allow create: if request.auth.uid == request.resource.data.fromUid;
      // The recipient can delete the invitation (accept/reject)
      allow delete: if request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid;
      allow update: if false; // invitations should not be updated, only created and deleted
    }
  }
}
