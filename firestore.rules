
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin role
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Questions can be read by any authenticated user, but only managed by admins.
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // Users collection rules
    match /users/{userId} {
      // Anyone authenticated can view user profiles (for leaderboards, etc.)
      allow read: if request.auth != null;
      
      // A user can create their own profile upon signup
      allow create: if request.auth != null && request.auth.uid == userId;

      // A user can only update their own profile data.
      allow update: if request.auth != null && request.auth.uid == userId;

      // Deletion of users is not allowed from the client.
      allow delete: if false;
    }

    // Game collection rules
    match /games/{gameId} {
        // Any authenticated user can create a game room.
        allow create: if request.auth != null;

        // Only players who are part of the game can read it.
        allow read: if request.auth != null && resource.data.players.exists(p, p.uid == request.auth.uid);

        // Only players who are part of the game can update it (e.g., join, update score).
        allow update: if request.auth != null && resource.data.players.exists(p, p.uid == request.auth.uid);
        
        // Deletion of games is not allowed from the client.
        allow delete: if false;
    }
  }
}
