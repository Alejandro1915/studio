rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isUserAdmin() {
      return isUserAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isGameHost() {
      return resource.data.hostId == request.auth.uid;
    }

    match /users/{userId} {
      allow read;
      allow update: if isUserAuthenticated() && isOwner(userId);
      allow create;
    }

    match /questions/{questionId} {
      allow read: if isUserAuthenticated();
      allow create, update, delete: if isUserAdmin();
    }

    match /games/{gameId} {
      allow read: if isUserAuthenticated();
      allow create: if isUserAuthenticated();
      allow update: if isUserAuthenticated(); 
    }
  }
}