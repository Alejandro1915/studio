rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth.uid == userId;
    }

    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    match /games/{gameId} {
      function isHost() {
        return request.auth.uid == resource.data.hostId;
      }
      function isPlayer() {
        // Check if the players list exists before trying to access it
        return 'players' in resource.data && request.auth.uid in resource.data.players.map(p => p.uid);
      }
      
      // Any authenticated user can read game data
      allow read: if request.auth != null;
      
      // Only the host can create a game
      allow create: if request.resource.data.hostId == request.auth.uid;

      // Only the host or an existing player can update the game state
      allow update: if isHost() || isPlayer();
    }
    
    match /invitations/{invitationId} {
        // Any authenticated user can create an invitation
        allow create: if request.auth != null;
        // Only the recipient of the invite can modify or delete it
        allow read, update, delete: if request.auth.uid == resource.data.toUid;
    }
  }
}
