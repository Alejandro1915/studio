rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isUserAuthenticated() {
      return request.auth != null;
    }
    
    function isUserAdmin() {
      return isUserAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if isUserAuthenticated();
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
    }

    match /questions/{questionId} {
      allow read: if isUserAuthenticated();
      allow create, update, delete: if isUserAdmin();
    }
    
    match /games/{gameId} {
      // Anyone can create a new game
      allow create: if isUserAuthenticated();
      // Players in the game or host can read/update it
      allow read, update: if isUserAuthenticated() && (resource.data.hostId == request.auth.uid || request.auth.uid in resource.data.players.map(p => p.uid));
    }
  }
}
