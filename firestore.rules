rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Questions: Allow reads for any authenticated user, but only admins can write.
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users: Anyone can read profiles. Users can only create/update their own profile.
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }
    
    // Invitations: Only authenticated users can interact.
    // User can read/delete their own invitations.
    // User can create an invitation.
    match /invitations/{invitationId} {
      allow read, delete: if request.auth != null && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.toUid;
    }

    // Games: Authenticated users can create games. Only players in the game can read/update it.
    match /games/{gameId} {
      
      // Allow user to create a game if they are the host
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;

      // Allow players in the game to read or update it.
      allow read, update: if request.auth != null && request.auth.uid in resource.data.players;
      
      allow delete: if false;
    }
  }
}
