rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas para la colección de usuarios
    match /users/{userId} {
      // Cualquiera puede leer la información de un usuario (necesario para el perfil público, etc.)
      allow get;
      // Solo el propio usuario o un administrador pueden leer la lista completa o su propio documento
      allow read, update, delete: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      // Cualquiera puede crear un usuario (registrarse)
      allow create;
    }

    // Reglas para la colección de preguntas
    match /questions/{questionId} {
      // Cualquiera puede leer las preguntas para jugar
      allow read;
      // Solo los administradores pueden crear, actualizar o eliminar preguntas
      allow create, update, delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
