
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Reglas para la colección 'users'
    match /users/{userId} {
      // Cualquiera puede leer los perfiles (para la tabla de clasificación)
      allow read: if request.auth != null;
      // Un usuario solo puede crear su propio perfil
      allow create: if request.auth.uid == userId;
      // Un usuario solo puede actualizar su propio perfil (nombre, foto)
      allow update: if request.auth.uid == userId && request.resource.data.keys().hasAll(['name', 'photoURL']);
      // Nadie puede eliminar usuarios desde el cliente
      allow delete: if false;
    }

    // Reglas para la colección 'questions'
    match /questions/{questionId} {
        // Cualquiera puede leer las preguntas para jugar
        allow read: if request.auth != null;
        // Solo los administradores pueden crear, actualizar y eliminar preguntas
        allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Reglas para la colección 'games'
    match /games/{gameId} {
        // Cualquiera puede leer las partidas
        allow read: if request.auth != null;
        // Cualquiera puede crear una partida
        allow create: if request.auth != null;
        // Solo un jugador de la partida puede actualizarla
        allow update: if request.auth != null && request.auth.uid in resource.data.players.map(p => p.uid);
        // El anfitrión puede eliminar la sala de espera
        allow delete: if request.auth != null && request.auth.uid == resource.data.hostId;
    }
  }
}
