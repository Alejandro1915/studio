rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isUserAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    match /users/{userId} {
      allow read: if isUserAuthenticated();
      allow write: if isOwner(userId);
    }

    match /questions/{questionId} {
      allow read: if isUserAuthenticated();
      // Allow write only for admins
      allow write: if request.auth.token.role == 'admin';
    }

    match /games/{gameId} {
      // Any authenticated user can read a game state.
      allow read: if isUserAuthenticated();

      // A user can create a game if they set themselves as the host.
      allow create: if isUserAuthenticated() && request.resource.data.hostId == request.auth.uid;
      
      // An update is allowed if:
      // 1. The user is the host.
      // OR
      // 2. The user is adding themselves to the player list AND the game is waiting for players.
      allow update: if isUserAuthenticated() && 
                    (request.auth.uid == resource.data.hostId || 
                    (request.auth.uid in request.resource.data.players && resource.data.players.size() < 2));

      allow delete: if false; // Games should not be deleted by clients.
    }

    match /invitations/{invitationId} {
        // Allow read only by the recipient of the invitation.
        allow read: if isUserAuthenticated() && request.auth.uid == resource.data.toUid;
        
        // Allow creation by the sender.
        allow create: if isUserAuthenticated() && request.auth.uid == request.resource.data.fromUid;

        // Allow update/delete by the recipient or sender.
        allow write: if isUserAuthenticated() && (request.auth.uid == resource.data.toUid || request.auth.uid == resource.data.fromUid);
    }
  }
}
